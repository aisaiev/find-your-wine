{
  "manifest_version": 2,
  "name": "Find Your Wine 🍷",
  "short_name": "Find Your Wine 🍷",
  "description": "The easiest way to find your wine in the different stores. It shows Vivino score on shop pages.",
  "author": "Anton Isaiev",
  "version": "1.4",
  "permissions": [
    "tabs"
  ],
  "background": {
    "scripts": [
        "background.js",
        "runtime.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://auchan.zakaz.ua/*",
        "*://winetime.com.ua/*",
        "*://goodwine.com.ua/*",
        "*://rozetka.com.ua/*"
      ],
      "js": [
        "content-script.js",
        "runtime.js"
      ]
    }
  ],
  "icons": {
    "128": "assets/img/icon.png"
  }
}
